   "source": [
    "import pandas as pd\n",
    "df = pd.DataFrame({\n",
    "    '班级': [1, 1, 2, 2],\n",
    "    '科目': ['语文', '数学', '语文', '数学'],\n",
    "    '分数': [90, 85, 88, 92]\n",
    "})\n",
    "pivot_df = df.pivot(index='班级', columns='科目', values='分数')\n",
    "df"
   ]
