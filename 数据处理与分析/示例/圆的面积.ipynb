   "source": [
    "import math\n",
    "\n",
    "# 输入半径\n",
    "r = float(input(\"请输入圆的半径：\"))\n",
    "\n",
    "# 计算面积 (πr²)\n",
    "area = math.pi * r ** 2\n",
    "\n",
    "# 输出结果\n",
    "print(f\"半径为 {r} 的圆，面积是：{area:.2f}\")"
   ]
  }
 ],
