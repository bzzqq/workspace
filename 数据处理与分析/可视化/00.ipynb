    "# 库存量可视化示例\n",
    "import matplotlib.pyplot as plt\n",
    "# 设置全局字体（Windows/Linux适用）\n",
    "plt.rcParams['font.sans-serif'] = ['SimHei']  # 黑体\n",
    "plt.rcParams['axes.unicode_minus'] = False  # 解决负号显示问题\n",
    "\n",
    "items = [\"托盘\", \"包装箱\", \"安全帽\"]\n",
    "counts = [120, 850, 3000]\n",
    "plt.bar(items, counts)\n",
    "plt.title(\"仓库库存量统计\")\n",
    "plt.show()"
   ]
  }
